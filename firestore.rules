rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: only the owner can read/write their own doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Lists are capability-based: the listId UUID acts as a bearer token, so any
    // authenticated user (including anonymous) who has the link may read and edit.
    // This intentionally preserves the app's frictionless "share a URL" model; the
    // only hardening over the previous behavior is that auth is now required at all.
    match /lists/{listId} {
      allow read: if request.auth != null;

      // Create: the caller must stamp themselves as owner and member.
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // Update: permitted for ownerless (legacy/claimable) lists, for existing
      // members, or when the only effect is the caller joining as a member.
      allow update: if request.auth != null
        && (
             !('ownerId' in resource.data)
             || resource.data.ownerId == null
             || request.auth.uid in resource.data.members
             || request.auth.uid in request.resource.data.members
           );

      allow delete: if false;
    }
  }
}
